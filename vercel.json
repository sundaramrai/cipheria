{
  "version": 2,
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{frontend/**,node_modules/**,.next/**,.vercel/**,.git/**,api/.venv/**,api/.ruff_cache/**,api/__pycache__/**,alembic/**,alembic.ini,**/*.pyc}"
    }
  },
  "regions": [
    "sin1"
  ],
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.14",
        "maxDuration": 10
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
